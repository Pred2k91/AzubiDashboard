# Vorlage: Kopieren nach ".env" (wird von Git ignoriert) und Werte eintragen.
# docker compose liest .env automatisch im selben Verzeichnis.

# Erstes Ausbilder-Konto — nur beim allerersten Start relevant.
# Leer lassen -> zufälliges Passwort wird beim ersten Start einmalig ins Backend-Log geschrieben.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Erst auf true stellen, wenn TLS (siehe Caddyfile / "caddy"-Service) aktiv ist.
COOKIE_SECURE=false
TRUST_PROXY=false

# SMTP-Mailversand — bleibt deaktiviert, bis die IT das freigibt.
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
APP_BASE_URL=http://localhost:3000

# Domain für den optionalen TLS-Reverse-Proxy (nur mit --profile tls aktiv)
SITE_DOMAIN=localhost

# Web Push (Workflows: Push-Benachrichtigungen aufs Handy) — erfordert HTTPS im Browser
# (oder localhost), sonst schlägt das Abonnieren dort fehl. Schlüssel einmalig erzeugen mit:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

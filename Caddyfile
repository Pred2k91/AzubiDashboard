# TLS-Reverse-Proxy — wird NICHT automatisch gestartet (siehe docker-compose.yml,
# Service "caddy" mit profiles: ["tls"]). Erforderlich für HTTPS (nötig z.B. für Web
# Push/Workflows), sonst weigern sich Browser, Service Worker/Push zu erlauben.
#
# Zwei Modi über TLS_MODE steuerbar, ohne diese Datei anzufassen:
#
# A) Selbstsigniert im LAN (TLS_MODE=internal, Standard) — funktioniert sofort ohne
#    Internet/Domain, z.B. Zugriff über die Server-IP im internen Netz:
#      1. SITE_DOMAIN=<Server-IP oder lokaler Name> in der .env setzen
#      2. TLS_MODE=internal (Standard, muss nicht extra gesetzt werden)
#      3. Port 443 am Host freigeben
#      4. docker compose --profile tls up -d --build
#      5. Beim backend-Service COOKIE_SECURE=true und TRUST_PROXY=true setzen und neu starten
#      6. Auf jedem Gerät beim ersten Aufruf die Zertifikatswarnung einmalig akzeptieren
#         ("Erweitert" → "Trotzdem fortfahren") — das ist normal bei selbstsignierten
#         Zertifikaten und muss nur einmal pro Gerät/Browser gemacht werden.
#
# B) Echte Domain beim Launch (später, für den Internet-Betrieb):
#      1. SITE_DOMAIN=ihre-domain.example in der .env setzen
#      2. TLS_MODE=admin@ihre-domain.example (echte Kontakt-E-Mail für Let's Encrypt)
#      3. Port 80 (ACME-Challenge) und 443 am Host freigeben
#      4. docker compose --profile tls up -d --build
#      Kein Zertifikatswarnung mehr, echtes von allen Geräten akzeptiertes Zertifikat.

{
	debug
	# Browser schicken bei einer nackten IP-Adresse (statt einem Hostnamen) bewusst kein
	# SNI im TLS-ClientHello (RFC 6066). Ohne default_sni versucht Caddy dann, das
	# Zertifikat anhand der internen Docker-Container-IP zu finden statt anhand der
	# tatsächlichen externen Adresse -- und findet keins ("internal error"-TLS-Alert).
	default_sni {$SITE_DOMAIN}
}

{$SITE_DOMAIN:localhost} {
	tls {$TLS_MODE}
	reverse_proxy frontend:80
}
